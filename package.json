{
  "name": "social-platform-frontend",
  "version": "5.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:feed dev:profile dev:discovery dev:web",
    "dev:web": "NUXT_TELEMETRY_DISABLED=1 nuxt dev --host 0.0.0.0 --port 5173",
    "dev:feed": "node services/feed-index.mjs",
    "dev:profile": "node services/profile-index.mjs",
    "dev:discovery": "node services/discovery-index.mjs",
    "build": "run-s type-check build:web",
    "preview": "HOST=0.0.0.0 PORT=5173 node .output/server/index.mjs",
    "build:web": "NUXT_TELEMETRY_DISABLED=1 nuxt build",
    "type-check": "NUXT_TELEMETRY_DISABLED=1 nuxt typecheck",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint app.vue nuxt.config.ts components composables lib services server tests e2e --fix",
    "lint:eslint": "eslint app.vue nuxt.config.ts components composables lib services server tests e2e --fix --cache",
    "format": "prettier --write .",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "playwright test e2e/smoke.spec.ts --project=chromium",
    "test:e2e": "playwright test e2e/realtime-feed.spec.ts --project=chromium",
    "test:all": "run-s test:unit test:integration test:smoke test:e2e"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "nuxt": "^4.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.11.0",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-playwright": "^2.8.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.50.0",
    "prettier": "3.8.1",
    "supertest": "^7.1.4",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
